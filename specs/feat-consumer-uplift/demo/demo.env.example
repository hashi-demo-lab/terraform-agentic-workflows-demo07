# ─── Demo Configuration ───────────────────────────────────────────────────────
# Copy to demo.env and fill in values:
#   cp demo.env.example demo.env
#
# These values are used by setup.sh, trigger-bump.sh, and teardown.sh

# ─── HCP Terraform ───────────────────────────────────────────────────────────
TFE_ORG="hashi-demos-apj"
TFE_PROJECT="sandbox"
TFE_HOSTNAME="app.terraform.io"

# Workspace name — auto-generated if empty (uses repo name)
# TFE_WORKSPACE=""

# ─── GitHub ──────────────────────────────────────────────────────────────────
# The demo repo created by create-demo-repos.zsh
# GITHUB_REPO="owner/repo-name"

# ─── Module Selection ────────────────────────────────────────────────────────
# Which PMR module to use for the demo
MODULE_NAME="s3-bucket"
MODULE_SOURCE="app.terraform.io/hashi-demos-apj/s3-bucket/aws"
MODULE_CURRENT_VERSION="5.8.2"

# Target version for the bump (set to latest when publishing a new version)
MODULE_TARGET_VERSION="5.8.2"

# ─── AWS Region ──────────────────────────────────────────────────────────────
AWS_REGION="ap-southeast-2"

# ─── Demo Scenario ───────────────────────────────────────────────────────────
# Which pipeline path to demonstrate:
#   patch    — version constraint change, plan shows changes (exit 2 → full pipeline)
#   minor    — adds new config alongside bump (exit 2 → full pipeline + AI analysis)
#   breaking — introduces error that fails plan (exit 1 → breaking-change path)
#   no-op    — version already applied (exit 0 → auto-close PR path)
DEMO_SCENARIO="minor"
